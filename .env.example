# Copy this to .env and fill in real values. Never commit .env.

# Home Assistant
HA_URL=http://192.168.1.137:8123
HA_TOKEN=

# Portainer
PORTAINER_URL=https://192.168.1.137:9443
PORTAINER_API_KEY=
PORTAINER_TLS_VERIFY=0

# Tuya IoT Platform (iot.tuya.com) — for tinytuya key extraction
# See homeassistant/docs/TUYA.md for full workflow
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_REGION=eu

# Tuya device local keys (from tinytuya wizard — see TUYA.md)
